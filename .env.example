# Goldmember — local environment variables.
# Copy this file to `.env` (in the same directory as docker-compose.yml) and fill
# in the real values. `.env` is gitignored so secrets stay on your machine.
#
# After editing, restart the container for the new values to be picked up:
#   docker compose up -d
# (no rebuild needed — the values are passed in at container start)

# OpenAI / chatbot
# Get a key at https://platform.openai.com/api-keys
# Leave empty to disable the chat widget (the endpoint will respond with HTTP 503).
CHATBOT_API_KEY=
