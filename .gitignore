# stay local. To exclude the entire suite, replace this block with `/tests/playwright/`.
/tests/playwright/audit_admin.py
/tests/playwright/audit_screens/
/tests/playwright/tests/test_auction_flow.py
/tests/playwright/tests/test_chat_scope_and_limit.py
